{{#each erros}}
    <div class="alert alert-danger">{{this.texto}}</div>
{{else}}
{{/each}}

<div class="card border-light mb-3">
    <div class="card-header">Preencha o Cadastro</div>
    <div class="card-body">
        <form action="/user/register" method="post">
        <div class="form-group">
            <label for="inputName">Nome completo</label>
            <input type="text" class="form-control" id="inputName" name="name" placeholder="Ruam Alberto de Souza" required>
        </div>
        <div class="form-group">
            <label for="inputEmail">Email</label>
            <input type="email" class="form-control" id="inputEmail" name="email" placeholder="example@email.com" required>
        </div>
        <div class="form-row">
            <div class="form-group col-md-6">
                <label for="inputNickName">Nome de usuário</label>
                <input oninput="verifyNickName()" type="text" class="form-control" id="inputNickName" name="nickname" placeholder="dev89" required>
            </div>
            <div class="form-group col-md-6">
                <label for="inputNationality">Nacionalidade</label>
                <select id="inputNationality" name="nationality" class="form-control" required>
                    <option selected>Selecionar nacionalidade...</option>
                    <option value="brasileiro">Brasileiro(a)</option>
                    <option value="argentino">Argentino(a)</option>
                    <option value="angolano">Angolano(a)</option>
                    <option value="alemao">Alemão(ã)</option>
                    <option value="americano">Americano(a)</option>
                    <option value="canadense">Canadense</option>
                    <option value="chileno">Chileno(a)</option>
                    <option value="chines">Chinês(a)</option>
                    <option value="colombiano">Colombiano(a)</option>
                    <option value="coreano">Coreano(a)</option>
                    <option value="espanhol">Espanhol(a)</option>
                    <option value="frances">Francês(a)</option>
                    <option value="italiano">Italiano(a)</option>
                    <option value="japones">Japonês(a)</option>
                    <option value="mocambicano">Moçambicano(a)</option>
                    <option value="paraguaio">Paraguaio(a)</option>
                    <option value="portugues">Português(a)</option>
                    <option value="uruguaio">Uruguaio(a)</option>
                    <option value="venezuelano">Venezuelano(a)</option>
                    <option value="outra">Outra</option>
                </select>
            </div>
        </div>
        <div class="form-row">
            <div class="form-group col-md-6">
                <label for="inputPassword">Senha</label>
                <input oninput="verifyPassword()" type="password" class="form-control" name="password" id="inputPassword" required
                        data-toggle="popover" 
                        data-placement="top"
                        data-content="* 8 caracteres"
                        data-template='<div class="popover" role="tooltip"><div class="arrow"></div><h3 class="popover-header"></h3><div style="color: red" class="popover-body"></div></div>'>
            </div>
            <div class="form-group col-md-6">
                <label for="inputPassword2">Repita a senha</label>
                <input type="password" class="form-control" name="password2" id="inputPassword2" required>
            </div>
        </div>
        <button disabled="" type="submit" id="btnRegister" class="btn btn-secondary">Registrar</button>
        </form>
    </div>
</div>
